{
  "info": {
    "name": "Clocked Notifications API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@clocked.in\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5004/api/admin/login"
        }
      }
    },
    {
      "name": "Get Notifications Log",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:5004/api/notifications/admin/notifications-log"
        }
      }
    },
    {
      "name": "Create Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Internal-Secret",
            "value": "test-secret"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"handle_searched\",\n  \"user_id\": \"69ccd81f63df08b16928d94a\",\n  \"variables\": {\n    \"handle\": \"testuser123\"\n  },\n  \"send_push\": false\n}"
        },
        "url": {
          "raw": "http://localhost:5004/api/internal/notifications/send"
        }
      }
    },
    {
      "name": "Mark Notification Read",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:5004/api/admin/notifications-log/{{notificationId}}/mark-read"
        }
      }
    },
    {
      "name": "Retry Push Notification",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:5004/api/admin/notifications-log/{{notificationId}}/retry"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string"
    }
  ]
}
